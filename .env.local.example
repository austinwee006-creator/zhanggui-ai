# 掌柜 AI 环境变量范例。复制成 .env.local 并填入真实值。

# AI（沿用现有）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 内部/家族共享密码（demo 与内部登入用；不填则不启用共享密码登入）
ACCESS_PASSWORD=

# Supabase（填了才会启用「注册 / 登入 / 云端同步 / 跨电脑使用」；不填则自动降级为纯本地模式）
# 在 Supabase 控制台 → Project Settings → API 取得
# Vercel Production / Preview 也要填同样两个值
# 重设密码跳转要到 Supabase Authentication → URL Configuration 加入：
# https://你的线上域名/login?reset=1
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 实体 POS / webhook 自动接入（只放服务端，不能公开）
# SUPABASE_SERVICE_ROLE_KEY 在 Supabase Project Settings → API → service_role 取得
# POS_INGEST_TOKEN 可选，只给内部后台兼容测试；客户 POS token 请在 /pos 由每家店自己生成
SUPABASE_SERVICE_ROLE_KEY=
POS_INGEST_TOKEN=
